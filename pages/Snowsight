    </div>`;
    $('#rowCount').textContent = '—';
    return;
  }
  $('#rowCount').textContent = formatNum(r.rows);

  if (r.rows === 0) {
    tablePane.innerHTML = `<div class="result-empty">
      <svg viewBox="0 0 64 64" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="10" y="14" width="44" height="36" rx="2"/><path d="M10 24h44M22 14v36"/></svg>
      <div class="title">Query returned 0 rows</div>
      <div class="hint">Statement executed but no rows matched</div>
    </div>`;
  } else {
    const tbl = el('table', { class: 'result-table' });
    const thead = el('thead');
    const headRow = el('tr');
    headRow.appendChild(el('th', { style: 'width: 50px;' }, '#'));
    const colTypes = r.columns.map((_, j) => inferColType(r.values, j));
    for (let j = 0; j < r.columns.length; j++) {
      headRow.appendChild(el('th', {},
        r.columns[j],
        el('span', { class: 'col-meta' }, colTypes[j])
      ));
    }
    thead.appendChild(headRow);
    tbl.appendChild(thead);
    const tbody = el('tbody');
    const max = Math.min(r.rows, 1000);
    for (let i = 0; i < max; i++) {
      const tr = el('tr', { class: 'row-num' });
      tr.appendChild(el('td', {}, String(i + 1)));
      const row = r.values[i];
      for (let j = 0; j < r.columns.length; j++) {
        tr.appendChild(renderCell(row[j], colTypes[j]));
      }
      tbody.appendChild(tr);
    }
    tbl.appendChild(tbody);
    tablePane.innerHTML = '';
    tablePane.appendChild(tbl);
    if (r.rows > max) {
      tablePane.appendChild(el('div', {
        style: 'padding: 12px 16px; font-size: 12px; color: var(--text-3); border-top: 1px solid var(--border-1); background: var(--bg-2); text-align: center;'
      }, `Showing first ${formatNum(max)} of ${formatNum(r.rows)} rows · use Export CSV for full result`));
    }
  }
  renderQueryDetails();
  if (state.chartCfg) renderChart();
}
function inferColType(rows, colIdx) {
  for (const r of rows) {
    const v = r[colIdx];
    if (v == null) continue;
    if (typeof v === 'number') return 'numeric';
    if (typeof v === 'string') {
      if (/^\d{4}-\d{2}-\d{2}/.test(v)) return 'date';
      return 'string';
    }
    if (typeof v === 'boolean') return 'bool';
    return 'string';
  }
  return 'string';
}
function renderCell(v, colType) {
  if (v == null) return el('td', { class: 'null' }, 'NULL');
  let display, cls = colType;
  if (typeof v === 'number') { display = formatNumber(v); cls = 'numeric'; }
  else if (typeof v === 'string') {
    display = v;
    if (/^\d{4}-\d{2}-\d{2}/.test(v)) cls = 'date';
  } else if (typeof v === 'boolean') {
    display = v ? 'true' : 'false';
    cls = 'bool';
  } else display = String(v);
  return el('td', { class: cls, title: String(v) }, display);
}

