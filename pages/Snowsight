// ---------- Charts ----------
function detectChartConfig(cols, rows) {
  if (!cols || cols.length < 2 || !rows.length) return null;
  let xIdx = -1;
  const numericCols = [];
  for (let j = 0; j < cols.length; j++) {
    let isNum = true;
    for (const r of rows.slice(0, 50)) {
      if (r[j] != null && typeof r[j] !== 'number') { isNum = false; break; }
    }
    if (isNum) numericCols.push(j);
    else if (xIdx === -1) xIdx = j;
  }
  if (xIdx === -1) xIdx = 0;
  let yIdx = numericCols.find(j => j !== xIdx);
  if (yIdx == null) return null;
  const sample = rows[0][xIdx];
  const isDate = typeof sample === 'string' && /^\d{4}-\d{2}/.test(sample);
  return { xIdx, yIdx, type: isDate ? 'line' : 'bar' };
}

function renderChart() {
  const pane = $('#pane-chart');
  const r = state.results;
  if (!r || !r.values.length) {
    pane.innerHTML = '<div class="result-empty"><svg viewBox="0 0 64 64" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M10 50h44M14 46V30M28 46V14M42 46V24M54 46V20"/></svg><div class="title">No data to chart</div></div>';
    return;
  }
  let cfg = state.chartCfg;
  if (!cfg) {
    pane.innerHTML = `<div class="result-empty">
      <svg viewBox="0 0 64 64" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M10 50h44M14 46V30M28 46V14M42 46V24M54 46V20"/></svg>
      <div class="title">No chartable data</div>
      <div class="hint">Need at least one categorical and one numeric column</div>
    </div>`;
    return;
  }
  pane.innerHTML = '';
  const tb = el('div', { class: 'chart-toolbar' },
    el('span', {}, 'Type'),
    selectInput([{value:'bar',label:'Bar'},{value:'line',label:'Line'},{value:'scatter',label:'Scatter'}], cfg.type, v => { cfg.type = v; renderChart(); }),
    el('span', { style: 'margin-left:12px;' }, 'X axis'),
    selectInput(r.columns.map((c, i) => ({ value: i, label: c })), cfg.xIdx, v => { cfg.xIdx = +v; renderChart(); }),
    el('span', { style: 'margin-left:12px;' }, 'Y axis'),
    selectInput(r.columns.map((c, i) => ({ value: i, label: c })), cfg.yIdx, v => { cfg.yIdx = +v; renderChart(); })
  );
  pane.appendChild(tb);

  const area = el('div', { class: 'chart-area' });
  pane.appendChild(area);

  const data = r.values.slice(0, 200).map(row => ({ x: row[cfg.xIdx], y: row[cfg.yIdx] }))
    .filter(d => d.y != null && typeof d.y === 'number');

  // Defer to next frame so chart-area has dimensions
  requestAnimationFrame(() => {
    const W = area.clientWidth || 600;
    const H = area.clientHeight || 280;
    area.innerHTML = '';
    area.appendChild(buildChartSVG(data, cfg.type, W, H, r.columns[cfg.xIdx], r.columns[cfg.yIdx]));
  });
}

function selectInput(opts, current, onChange) {
  const sel = el('select', { onchange: e => onChange(e.target.value) });
  for (const o of opts) {
    const value = typeof o === 'object' ? o.value : o;
    const label = typeof o === 'object' ? o.label : o;
    const opt = el('option', { value }, label);
    if (String(value) === String(current)) opt.selected = true;
    sel.appendChild(opt);
  }
  return sel;
}

function buildChartSVG(data, type, W, H, xLabel, yLabel) {
  const padL = 60, padR = 16, padT = 16, padB = 40;
  const w = Math.max(50, W - padL - padR);
  const h = Math.max(50, H - padT - padB);
  const ns = 'http://www.w3.org/2000/svg';
  const svg = document.createElementNS(ns, 'svg');
  svg.setAttribute('class', 'chart-svg');
  svg.setAttribute('viewBox', `0 0 ${W} ${H}`);
  svg.setAttribute('preserveAspectRatio', 'none');

  const defs = document.createElementNS(ns, 'defs');
  defs.innerHTML = `
    <linearGradient id="bar-gradient" x1="0" y1="0" x2="0" y2="1">
      <stop offset="0%" stop-color="#29B5E8" stop-opacity="0.9"/>
      <stop offset="100%" stop-color="#1A6F94" stop-opacity="0.6"/>
    </linearGradient>
    <linearGradient id="area-gradient" x1="0" y1="0" x2="0" y2="1">
      <stop offset="0%" stop-color="#29B5E8" stop-opacity="0.4"/>
      <stop offset="100%" stop-color="#29B5E8" stop-opacity="0"/>
    </linearGradient>`;
  svg.appendChild(defs);
  if (!data.length) return svg;

  const ys = data.map(d => d.y);
  const yMax = Math.max(...ys, 0);
  const yMin = Math.min(...ys, 0);
  const yRange = (yMax - yMin) || 1;

  // Y grid + labels
  const yTicks = 5;
  for (let i = 0; i <= yTicks; i++) {
    const y = padT + h - (i / yTicks) * h;
    const v = yMin + (i / yTicks) * yRange;
    const line = document.createElementNS(ns, 'line');
    line.setAttribute('class', 'grid');
    line.setAttribute('x1', padL); line.setAttribute('x2', W - padR);
    line.setAttribute('y1', y); line.setAttribute('y2', y);
    svg.appendChild(line);
    const lbl = document.createElementNS(ns, 'text');
    lbl.setAttribute('class', 'axis-label');
    lbl.setAttribute('x', padL - 6); lbl.setAttribute('y', y + 4);
    lbl.setAttribute('text-anchor', 'end');
    lbl.textContent = formatNumber(v);
    svg.appendChild(lbl);
  }

  if (type === 'bar') {
    const bw = w / data.length;
    const barW = Math.max(2, bw * 0.7);
    for (let i = 0; i < data.length; i++) {
      const d = data[i];
      const x = padL + i * bw + (bw - barW) / 2;
      const yY = padT + h - ((d.y - yMin) / yRange) * h;
      const yZ = padT + h - ((0 - yMin) / yRange) * h;
      const top = Math.min(yY, yZ);
      const height = Math.max(1, Math.abs(yY - yZ));
      const rect = document.createElementNS(ns, 'rect');
      rect.setAttribute('class', 'bar');
      rect.setAttribute('x', x); rect.setAttribute('y', top);
      rect.setAttribute('width', barW); rect.setAttribute('height', height);
      rect.setAttribute('rx', 2);
      const t = document.createElementNS(ns, 'title');
      t.textContent = `${d.x}: ${formatNumber(d.y)}`;
      rect.appendChild(t);
      svg.appendChild(rect);
    }
    addXLabels(svg, data, padL, w, H, padB, ns, i => padL + i * (w / data.length) + (w / data.length) / 2);
  } else if (type === 'line') {
    const xPos = i => padL + (i / Math.max(1, data.length - 1)) * w;
    const yPos = v => padT + h - ((v - yMin) / yRange) * h;

    let dPath = `M ${xPos(0)} ${padT + h}`;
    for (let i = 0; i < data.length; i++) dPath += ` L ${xPos(i)} ${yPos(data[i].y)}`;
    dPath += ` L ${xPos(data.length - 1)} ${padT + h} Z`;
    const areaP = document.createElementNS(ns, 'path');
    areaP.setAttribute('class', 'area');
    areaP.setAttribute('d', dPath);
    svg.appendChild(areaP);

    let lp = '';
    for (let i = 0; i < data.length; i++) lp += (i === 0 ? 'M ' : ' L ') + xPos(i) + ' ' + yPos(data[i].y);
    const lineP = document.createElementNS(ns, 'path');
    lineP.setAttribute('class', 'line');
    lineP.setAttribute('d', lp);
    svg.appendChild(lineP);

    for (let i = 0; i < data.length; i++) {
      const c = document.createElementNS(ns, 'circle');
      c.setAttribute('class', 'point');
      c.setAttribute('cx', xPos(i)); c.setAttribute('cy', yPos(data[i].y));
      c.setAttribute('r', 3);
      const t = document.createElementNS(ns, 'title');
      t.textContent = `${data[i].x}: ${formatNumber(data[i].y)}`;
      c.appendChild(t);
      svg.appendChild(c);
    }
    addXLabels(svg, data, padL, w, H, padB, ns, xPos);
  } else {
    // scatter
    const xPos = i => padL + (i / Math.max(1, data.length - 1)) * w;
    const yPos = v => padT + h - ((v - yMin) / yRange) * h;
    for (let i = 0; i < data.length; i++) {
      const c = document.createElementNS(ns, 'circle');
      c.setAttribute('class', 'point');
      c.setAttribute('cx', xPos(i)); c.setAttribute('cy', yPos(data[i].y));
      c.setAttribute('r', 4);
      svg.appendChild(c);
    }
    addXLabels(svg, data, padL, w, H, padB, ns, xPos);
  }

  // Axis lines
  const ax = document.createElementNS(ns, 'line');
  ax.setAttribute('class', 'axis');
  ax.setAttribute('x1', padL); ax.setAttribute('x2', W - padR);
  ax.setAttribute('y1', padT + h); ax.setAttribute('y2', padT + h);
  svg.appendChild(ax);
  const ay = document.createElementNS(ns, 'line');
  ay.setAttribute('class', 'axis');
  ay.setAttribute('x1', padL); ay.setAttribute('x2', padL);
  ay.setAttribute('y1', padT); ay.setAttribute('y2', padT + h);
  svg.appendChild(ay);

  // Axis titles
  const xt = document.createElementNS(ns, 'text');
  xt.setAttribute('class', 'axis-title');
  xt.setAttribute('x', padL + w / 2); xt.setAttribute('y', H - 6);
  xt.setAttribute('text-anchor', 'middle');
  xt.textContent = xLabel;
  svg.appendChild(xt);
  const yt = document.createElementNS(ns, 'text');
  yt.setAttribute('class', 'axis-title');
  yt.setAttribute('transform', `rotate(-90, 14, ${padT + h / 2})`);
  yt.setAttribute('x', 14); yt.setAttribute('y', padT + h / 2);
  yt.setAttribute('text-anchor', 'middle');
  yt.textContent = yLabel;
  svg.appendChild(yt);

  return svg;
}
function addXLabels(svg, data, padL, w, H, padB, ns, xPos) {
  const labelCount = Math.min(data.length, 10);
  const step = Math.max(1, Math.ceil(data.length / labelCount));
  for (let i = 0; i < data.length; i += step) {
    const lbl = document.createElementNS(ns, 'text');
    lbl.setAttribute('class', 'axis-label');
    lbl.setAttribute('x', xPos(i)); lbl.setAttribute('y', H - padB + 16);
    lbl.setAttribute('text-anchor', 'middle');
    const t = String(data[i].x);
    lbl.textContent = t.length > 14 ? t.slice(0, 12) + '…' : t;
    svg.appendChild(lbl);
  }
}

