// ---------- TPCH data generator ----------
function generateTPCH() {
  const out = { region: [], nation: [], customer: [], supplier: [], part: [], partsupp: [], orders: [], lineitem: [] };
  for (const r of TPCH_REGIONS) out.region.push(r);
  for (const n of TPCH_NATIONS) out.nation.push([n[0], n[1], n[2], `nation ${n[1]} comment`]);

  const N_CUSTOMERS = 600;
  for (let i = 1; i <= N_CUSTOMERS; i++) {
    out.customer.push([
      i,
      `Customer#${String(i).padStart(9, '0')}`,
      `${rint(1, 9999)} ${pick(['Main','Oak','Pine','Maple','Elm'])} St`,
      rint(0, 24),
      `${rint(10,34)}-${rint(100,999)}-${rint(100,999)}-${rint(1000,9999)}`,
      Math.round(rfloat(-1000, 10000) * 100) / 100,
      pick(MKT_SEGMENTS),
      'regular accounts pending'
    ]);
  }

  const N_SUPPLIERS = 50;
  for (let i = 1; i <= N_SUPPLIERS; i++) {
    out.supplier.push([
      i,
      `Supplier#${String(i).padStart(9, '0')}`,
      `${rint(1, 9999)} ${pick(['Industrial','Commerce','Trade','Market'])} Way`,
      rint(0, 24),
      `${rint(10,34)}-${rint(100,999)}-${rint(100,999)}-${rint(1000,9999)}`,
      Math.round(rfloat(-1000, 10000) * 100) / 100,
      'each slyly bold'
    ]);
  }

  const N_PARTS = 800;
  for (let i = 1; i <= N_PARTS; i++) {
    const mfgrId = rint(1, 5);
    out.part.push([
      i,
      `${pick(COLORS)} ${pick(COLORS)} ${pick(['oxide','metal','polish','stain'])} part`,
      `Manufacturer#${mfgrId}`,
      `Brand#${mfgrId}${rint(1,5)}`,
      pick(PART_TYPES),
      rint(1, 50),
      pick(PART_CONTAINERS),
      Math.round(rfloat(900, 2099) * 100) / 100,
      'p comment'
    ]);
  }

  // Build supplier list per part once for efficiency
  const partSuppliers = new Map();
  for (let pk = 1; pk <= N_PARTS; pk++) {
    const supps = new Set();
    while (supps.size < 4) supps.add(rint(1, N_SUPPLIERS));
    const arr = [...supps];
    partSuppliers.set(pk, arr);
    for (const sk of arr) {
      out.partsupp.push([
        pk, sk, rint(1, 9999),
        Math.round(rfloat(1, 1000) * 100) / 100,
        'ps comment'
      ]);
    }
  }

  const N_ORDERS = 6000;
  const startDate = new Date('1998-01-01').getTime();
  const endDate = new Date('2024-06-30').getTime();
  for (let i = 1; i <= N_ORDERS; i++) {
    const orderDate = new Date(startDate + rng() * (endDate - startDate)).toISOString().slice(0, 10);
    const status = pickWeighted(['O','F','P'], [3, 5, 1]);
    out.orders.push([
      i,
      rint(1, N_CUSTOMERS),
      status,
      0,
      orderDate,
      pick(ORDER_PRIORITIES),
      `Clerk#${String(rint(1, 50)).padStart(9, '0')}`,
      0,
      'order comment'
    ]);
  }

  const today = new Date().toISOString().slice(0, 10);
  for (const o of out.orders) {
    const orderKey = o[0];
    const orderDate = o[4];
    const numLines = rint(1, 7);
    let total = 0;
    for (let ln = 1; ln <= numLines; ln++) {
      const partKey = rint(1, N_PARTS);
      const part = out.part[partKey - 1];
      const supps = partSuppliers.get(partKey);
      const suppKey = supps[rint(0, supps.length - 1)];
      const qty = rint(1, 50);
      const price = part[7];
      const extPrice = Math.round(qty * price * 100) / 100;
      const discount = Math.round(rfloat(0, 0.10) * 100) / 100;
      const tax = Math.round(rfloat(0, 0.08) * 100) / 100;
      const shipDate = dateAddDays(orderDate, rint(1, 121));
      const commitDate = dateAddDays(orderDate, rint(30, 90));
      const receiptDate = dateAddDays(shipDate, rint(1, 30));
      const returnFlag = receiptDate < today ? pickWeighted(['R','A'], [1, 4]) : 'N';
      const lineStatus = shipDate < today ? 'F' : 'O';
      out.lineitem.push([
        orderKey, partKey, suppKey, ln,
        qty, extPrice, discount, tax,
        returnFlag, lineStatus,
        shipDate, commitDate, receiptDate,
        pick(SHIP_INSTRUCT), pick(SHIP_MODES),
        'l comment'
      ]);
      total += extPrice * (1 - discount) * (1 + tax);
    }
    o[3] = Math.round(total * 100) / 100;
  }

  return out;
}

