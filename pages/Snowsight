  $('#aiGenerateBtn').addEventListener('click', generateAiSql);
  $('#aiPrompt').addEventListener('keydown', e => {
    if ((e.ctrlKey || e.metaKey) && e.key === 'Enter') { e.preventDefault(); generateAiSql(); }
  });
  $('#newWsBtn2').addEventListener('click', () => newWorksheet());

  $('#refreshDbBtn').addEventListener('click', () => {
    renderTree();
    toast('Catalog refreshed', 'success');
  });

  // Mobile sidebar drawer
  const sidebar = $('#sidebar');
  const scrim = $('#sidebarScrim');
  const closeMobileSidebar = () => {
    sidebar.classList.remove('open');
    scrim.classList.remove('visible');
  };
  $('#mobileMenuBtn').addEventListener('click', () => {
    const open = sidebar.classList.toggle('open');
    scrim.classList.toggle('visible', open);
  });
  scrim.addEventListener('click', closeMobileSidebar);
  // Close drawer when desktop reflow takes over so state can't get stuck open
  window.addEventListener('resize', debounce(() => {
    if (window.innerWidth > 768) closeMobileSidebar();
  }, 100));
  // Close drawer after a sidebar selection on mobile so the user sees results
  sidebar.addEventListener('click', e => {
    if (window.innerWidth > 768) return;
    if (e.target.closest('.tree-row, .ws-item')) closeMobileSidebar();
  });

  $('#dbSearch').addEventListener('input', e => {
    state.treeFilter = e.target.value;
    renderTree();
  });

  // Result tabs
  $$('.result-tab').forEach(t => {
    t.addEventListener('click', () => switchResultPane(t.dataset.pane));
  });

  $('#exportCsvBtn').addEventListener('click', exportCsv);
  $('#copyCsvBtn').addEventListener('click', copyCsv);

  // Modals close
  $$('[data-close]').forEach(b => b.addEventListener('click', e => {
    e.target.closest('.modal-backdrop').classList.remove('open');
  }));
  $$('.modal-backdrop').forEach(b => {
    b.addEventListener('click', e => { if (e.target === b) b.classList.remove('open'); });
  });

  // (clearHistoryBtn lived in the old modal; the page-level Clear all button is wired above.)

  // Role / warehouse menus
  $('#rolePill').addEventListener('click', e => {
    e.stopPropagation();
    const roles = ['SYSADMIN','ACCOUNTADMIN','SECURITYADMIN','PUBLIC','USERADMIN'];
    openMenu($('#roleMenu'), $('#rolePill'), [
      { section: 'Switch role' },
      ...roles.map(r => ({
        label: r, active: state.context.role === r,
        onClick: () => {
          state.context.role = r;
          $('#roleName').textContent = r;
          toast(`Role switched to ${r}`, 'success');
        }
      }))
    ]);
  });
  $('#warehousePill').addEventListener('click', e => {
    e.stopPropagation();
    const sizes = ['X-Small','Small','Medium','Large','X-Large'];
    const warehouses = ['COMPUTE_WH','ANALYTICS_WH','LOAD_WH','REPORTING_WH'];
    openMenu($('#warehouseMenu'), $('#warehousePill'), [
      { section: 'Warehouse' },
      ...warehouses.map(w => ({
        label: w, active: state.context.warehouse === w,
        right: w === state.context.warehouse ? state.context.warehouseSize : '',
        onClick: () => {
          state.context.warehouse = w;
          $('#warehouseName').textContent = w;
          toast(`Resuming ${w}...`, 'success');
        }
      })),
      { divider: true },
      { section: 'Size' },
      ...sizes.map(s => ({
        label: s, active: state.context.warehouseSize === s,
        onClick: () => {
          state.context.warehouseSize = s;
          toast(`Warehouse resized to ${s}`, 'success');
        }
      }))
    ]);
  });
  document.addEventListener('click', e => {
    if (!e.target.closest('.menu') && !e.target.closest('.pill')) closeAllMenus();
  });

  // Resizer
  const resizer = $('#resizer');
  let resizeStartY = 0, startH = 0;
  const root = document.documentElement;
  resizer.addEventListener('mousedown', e => {
    resizeStartY = e.clientY;
    startH = parseInt(getComputedStyle(root).getPropertyValue('--results-h')) || 360;
    document.body.style.cursor = 'ns-resize';
    document.body.style.userSelect = 'none';
    const onMove = ev => {
      const dy = resizeStartY - ev.clientY;
      const newH = Math.max(120, Math.min(window.innerHeight - 200, startH + dy));
      root.style.setProperty('--results-h', newH + 'px');
    };
    const onUp = () => {
      document.removeEventListener('mousemove', onMove);
      document.removeEventListener('mouseup', onUp);
      document.body.style.cursor = '';
      document.body.style.userSelect = '';
      if (state.results) renderChart();
    };
    document.addEventListener('mousemove', onMove);
    document.addEventListener('mouseup', onUp);
  });

  // Window resize → re-render chart
  window.addEventListener('resize', debounce(() => {
    if (state.results && $('#pane-chart').classList.contains('active')) renderChart();
  }, 150));

  // Keyboard
  document.addEventListener('keydown', e => {
    if ((e.ctrlKey || e.metaKey) && e.key === 'k') {
      e.preventDefault();
      $('#dbSearch').focus();
    }
    if ((e.ctrlKey || e.metaKey) && e.key.toLowerCase() === 'i') {
      e.preventDefault();
      openAiModal();
    }
    if (e.key === 'Escape') {
      closeAllMenus();
      $$('.modal-backdrop.open').forEach(m => m.classList.remove('open'));
    }
  });
}

// ---------- Boot trigger ----------
document.addEventListener('DOMContentLoaded', () => {
  boot().catch(err => {
    console.error(err);
    $('#bootText').textContent = 'Boot failed: ' + err.message;
  });
});

</script>

</body>
</html>
