// ---------- Ask AI ----------
const AI_KEY_STORAGE = 'snowsight_v1_ai_key';
const AI_MODEL = 'claude-sonnet-4-6';
const AI_API_URL = 'https://api.anthropic.com/v1/messages';

function showAiPromptPanel() {
  $('#aiKeyMissing').hidden = true;
  $('#aiPromptPanel').hidden = false;
}
function showAiKeyPanel() {
  $('#aiKeyMissing').hidden = false;
  $('#aiPromptPanel').hidden = true;
}

function openAiModal() {
  $('#aiModal').classList.add('open');
  $('#aiStatus').textContent = '';
  $('#aiStatus').classList.remove('error');
  if (localStorage.getItem(AI_KEY_STORAGE)) {
    showAiPromptPanel();
    setTimeout(() => $('#aiPrompt').focus(), 50);
  } else {
    showAiKeyPanel();
    setTimeout(() => $('#aiKeyInput').focus(), 50);
  }
}

function saveAiKey() {
  const v = $('#aiKeyInput').value.trim();
  if (!v.startsWith('sk-ant-')) {
    toast('Invalid Anthropic key — should start with sk-ant-', 'error');
    return;
  }
  localStorage.setItem(AI_KEY_STORAGE, v);
  $('#aiKeyInput').value = '';
  showAiPromptPanel();
  setTimeout(() => $('#aiPrompt').focus(), 50);
}

// Compact schema description for the system prompt — small enough to send
// every call without caching, large enough to ground the model in the
// available tables and column names.
function buildAiSchemaContext() {
  const lines = [];
  for (const db of SCHEMA_META.databases) {
    for (const sc of db.schemas) {
      for (const t of sc.tables) {
        const cols = t.columns.map(c => `${c[0]} ${c[1]}`).join(', ');
        lines.push(`${db.name}.${sc.name}.${t.name}(${cols})`);
      }
    }
  }
  return lines.join('\n');
}

async function generateAiSql() {
  const prompt = $('#aiPrompt').value.trim();
  if (!prompt) { $('#aiPrompt').focus(); return; }
  const key = localStorage.getItem(AI_KEY_STORAGE);
  if (!key) { showAiKeyPanel(); return; }

  const status = $('#aiStatus');
  const btn = $('#aiGenerateBtn');
  status.textContent = 'Generating…';
  status.classList.remove('error');
  btn.disabled = true;

  try {
    const schema = buildAiSchemaContext();
    const system = `You are a Snowflake SQL expert. Generate one Snowflake-flavored SQL query for the user's request.

Output rules — these are strict:
- Output ONLY the SQL. No markdown fencing. No prose. No preamble. No trailing notes.
- Reference tables by their unqualified name (case-insensitive lower-case is fine).
- Use Snowflake idioms when they fit: QUALIFY for window-filter, IFF for inline conditional, DATEADD/DATEDIFF/DATE_TRUNC for dates, ::TYPE for casts, ILIKE for case-insensitive match.
- Inline -- comments are welcome but no separate explanation.

Available schema:
${schema}`;

    const resp = await fetch(AI_API_URL, {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
        'x-api-key': key,
        'anthropic-version': '2023-06-01',
        'anthropic-dangerous-direct-browser-access': 'true'
      },
      body: JSON.stringify({
        model: AI_MODEL,
        max_tokens: 1024,
        system,
        messages: [{ role: 'user', content: prompt }]
      })
    });

    if (!resp.ok) {
      const errBody = await resp.text();
      let msg = `${resp.status} ${resp.statusText}`;
      try {
        const j = JSON.parse(errBody);
        if (j.error && j.error.message) msg = j.error.message;
      } catch (_) {}
      throw new Error(msg);
    }

    const json = await resp.json();
    let sql = (json.content && json.content[0] && json.content[0].text || '').trim();
    sql = sql.replace(/^```\w*\s*/m, '').replace(/```\s*$/m, '').trim();
    if (!sql) throw new Error('No SQL returned by the model.');

    // Insert into the active worksheet at the cursor, with a comment recording the prompt
    const block = `\n-- Ask AI: ${prompt.replace(/\n/g, ' ')}\n${sql}\n`;
    const cur = editor.getDoc().getCursor();
    editor.getDoc().replaceRange(block, cur);
    editor.focus();

    $('#aiModal').classList.remove('open');
    $('#aiPrompt').value = '';
    toast('Generated — review and Run', 'success');
  } catch (err) {
    status.textContent = `Error: ${err.message}`;
    status.classList.add('error');
  } finally {
    btn.disabled = false;
  }
}

