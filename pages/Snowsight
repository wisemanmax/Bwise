// ---------- Export CSV ----------
function buildCsv() {
  const r = state.results;
  if (!r) return '';
  const esc = v => {
    if (v == null) return '';
    const s = String(v);
    return /[",\n\r]/.test(s) ? '"' + s.replace(/"/g, '""') + '"' : s;
  };
  let out = r.columns.map(esc).join(',') + '\n';
  for (const row of r.values) out += row.map(esc).join(',') + '\n';
  return out;
}
function exportCsv() {
  const csv = buildCsv();
  if (!csv) { toast('Nothing to export', 'warn'); return; }
  const blob = new Blob([csv], { type: 'text/csv' });
  const url = URL.createObjectURL(blob);
  const a = document.createElement('a');
  a.href = url;
  a.download = 'snowsight-results.csv';
  a.click();
  setTimeout(() => URL.revokeObjectURL(url), 1000);
  toast('CSV downloaded', 'success');
}
function copyCsv() {
  const csv = buildCsv();
  if (!csv) { toast('Nothing to copy', 'warn'); return; }
  navigator.clipboard.writeText(csv).then(
    () => toast('Copied as CSV', 'success'),
    () => toast('Copy failed', 'error')
  );
}

