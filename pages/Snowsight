async function formatSql() {
  if (!editor) return;
  const sql = editor.getValue();
  if (!sql.trim()) return;
  let formatted;
  try {
    const mod = await loadSqlFormatter();
    formatted = mod.format(sql, {
      language: 'snowflake',
      tabWidth: 2,
