<style>
:root {
  /* Snowflake brand palette */
  --sf-blue: #29B5E8;
  --sf-blue-dark: #11A6DC;
  --sf-blue-deep: #1A6F94;
  --sf-blue-pale: #6FCFEF;
  --sf-navy: #11567F;

/* Snowsight dark theme */
–bg-0: #0B0F19;
–bg-1: #11161F;
–bg-2: #161C28;
–bg-3: #1D2532;
–bg-4: #242C3B;
–surface-hover: #1F2632;
–surface-active: #243043;

–border-1: #1F2632;
–border-2: #2A3343;
–border-3: #354054;

–text-1: #E6EBF2;
–text-2: #9AA5B8;
–text-3: #6C7689;
–text-4: #4A5468;

–green: #2DD4A8;
–green-bg: rgba(45, 212, 168, 0.12);
–amber: #F5B544;
–red: #F86F7C;
–red-bg: rgba(248, 111, 124, 0.12);
–purple: #B088F9;

–shadow-sm: 0 1px 2px rgba(0,0,0,0.4);
–shadow-md: 0 4px 12px rgba(0,0,0,0.4);
–shadow-lg: 0 12px 32px rgba(0,0,0,0.5);

–radius-sm: 4px;
–radius-md: 6px;
–radius-lg: 8px;

–header-h: 44px;
–tabs-h: 36px;
–status-h: 28px;
–sidebar-w: 280px;
}

- { box-sizing: border-box; margin: 0; padding: 0; }
  html, body { height: 100%; overflow: hidden; }
  body {
  font-family: ‘Inter’, -apple-system, BlinkMacSystemFont, sans-serif;
  background: var(–bg-0);
  color: var(–text-1);
  font-size: 13px;
  line-height: 1.45;
  -webkit-font-smoothing: antialiased;
  -moz-osx-font-smoothing: grayscale;
  }
  button { font-family: inherit; cursor: pointer; border: none; background: none; color: inherit; }
  input, select, textarea { font-family: inherit; }

/* ============================================================
APP SHELL
============================================================ */
.app {
display: grid;
grid-template-rows: var(–header-h) 1fr var(–status-h);
height: 100vh;
height: 100dvh; /* mobile: respects iOS Safari address bar */
}

/* ===== Top header (Snowflake nav) ===== */
.topbar {
display: flex;
align-items: center;
background: var(–bg-1);
border-bottom: 1px solid var(–border-1);
height: var(–header-h);
padding: 0 12px;
gap: 4px;
position: relative;
z-index: 50;
}
.brand {
display: flex;
align-items: center;
gap: 8px;
padding: 0 12px 0 4px;
margin-right: 8px;
}
.brand-mark {
width: 22px;
height: 22px;
flex-shrink: 0;
}
.brand-text {
font-weight: 600;
font-size: 14px;
color: var(–text-1);
letter-spacing: -0.01em;
}
.nav-tabs {
display: flex;
gap: 0;
height: 100%;
align-items: stretch;
}
.nav-tab {
display: flex;
align-items: center;
padding: 0 14px;
font-size: 13px;
font-weight: 500;
color: var(–text-2);
border-bottom: 2px solid transparent;
margin-bottom: -1px;
transition: color 120ms;
}
.nav-tab:hover { color: var(–text-1); }
.nav-tab.active {
color: var(–text-1);
border-bottom-color: var(–sf-blue);
}
.nav-tab svg { width: 14px; height: 14px; margin-right: 6px; }

.topbar-spacer { flex: 1; }

.context-pills {
display: flex;
align-items: center;
gap: 6px;
}
.pill {
display: inline-flex;
align-items: center;
gap: 6px;
height: 28px;
padding: 0 10px;
background: var(–bg-2);
border: 1px solid var(–border-2);
border-radius: var(–radius-md);
color: var(–text-1);
font-size: 12px;
font-weight: 500;
white-space: nowrap;
transition: background 120ms, border-color 120ms;
}
.pill:hover { background: var(–surface-hover); border-color: var(–border-3); }
.pill .label {
color: var(–text-3);
font-weight: 400;
font-size: 11px;
}
.pill .caret {
width: 10px; height: 10px; opacity: 0.6;
}
.pill .dot {
width: 6px; height: 6px; border-radius: 50%;
background: var(–green);
box-shadow: 0 0 6px rgba(45, 212, 168, 0.6);
}
.icon-btn {
width: 30px; height: 30px;
border-radius: var(–radius-md);
display: inline-flex;
align-items: center;
justify-content: center;
color: var(–text-2);
transition: background 120ms, color 120ms;
}
.icon-btn:hover { background: var(–bg-2); color: var(–text-1); }
.icon-btn svg { width: 16px; height: 16px; }

.avatar {
width: 28px; height: 28px;
border-radius: 50%;
background: linear-gradient(135deg, var(–sf-blue), var(–sf-blue-deep));
color: white;
display: inline-flex;
align-items: center;
justify-content: center;
font-size: 11px;
font-weight: 600;
margin-left: 4px;
text-decoration: none;
cursor: pointer;
transition: transform 120ms;
}
.avatar:hover { transform: scale(1.05); }

/* ===== Main grid ===== */
.main {
display: grid;
grid-template-columns: var(–sidebar-w) 1fr;
overflow: hidden;
min-height: 0;
}

/* ===== Sidebar ===== */
.sidebar {
background: var(–bg-1);
border-right: 1px solid var(–border-1);
display: flex;
flex-direction: column;
min-width: 0;
overflow: hidden;
}
.sidebar-section { border-bottom: 1px solid var(–border-1); display: flex; flex-direction: column; min-height: 0; }
.sidebar-section.flex { flex: 1; }
.sidebar-header {
display: flex;
align-items: center;
padding: 10px 12px 6px;
font-size: 11px;
font-weight: 600;
color: var(–text-3);
text-transform: uppercase;
letter-spacing: 0.05em;
user-select: none;
}
.sidebar-header .actions {
margin-left: auto;
display: flex;
gap: 2px;
opacity: 0;
transition: opacity 120ms;
}
.sidebar-section:hover .sidebar-header .actions { opacity: 1; }
.sidebar-header .icon-btn {
width: 22px; height: 22px;
}
.sidebar-header .icon-btn svg { width: 12px; height: 12px; }

.search-box {
margin: 0 8px 8px;
position: relative;
}
.search-box svg {
position: absolute;
left: 8px;
top: 50%;
transform: translateY(-50%);
width: 12px;
height: 12px;
color: var(–text-3);
pointer-events: none;
}
.search-box input {
width: 100%;
height: 26px;
padding: 0 8px 0 26px;
background: var(–bg-2);
border: 1px solid var(–border-2);
border-radius: var(–radius-md);
color: var(–text-1);
font-size: 12px;
outline: none;
transition: border-color 120ms;
}
.search-box input:focus { border-color: var(–sf-blue); }
.search-box input::placeholder { color: var(–text-3); }

.tree {
overflow-y: auto;
padding: 0 4px 8px;
flex: 1;
}
.tree-node {
user-select: none;
}
.tree-row {
display: flex;
align-items: center;
padding: 3px 4px 3px 0;
font-size: 12.5px;
color: var(–text-1);
border-radius: var(–radius-sm);
cursor: pointer;
white-space: nowrap;
overflow: hidden;
transition: background 80ms;
}
.tree-row:hover { background: var(–surface-hover); }
.tree-row.active { background: var(–surface-active); color: var(–sf-blue); }
.tree-row .twisty {
width: 16px; height: 16px;
display: inline-flex;
align-items: center;
justify-content: center;
flex-shrink: 0;
color: var(–text-3);
transition: transform 120ms;
}
.tree-row .twisty svg { width: 9px; height: 9px; }
.tree-row.expanded .twisty { transform: rotate(90deg); }
.tree-row.no-twisty .twisty { visibility: hidden; }
.tree-row .icon {
width: 16px; height: 16px;
display: inline-flex;
align-items: center;
justify-content: center;
flex-shrink: 0;
margin-right: 4px;
color: var(–text-2);
}
.tree-row .icon svg { width: 13px; height: 13px; }
.tree-row .label {
flex: 1;
overflow: hidden;
text-overflow: ellipsis;
font-weight: 400;
}
.tree-row .badge {
font-size: 10px;
color: var(–text-3);
background: var(–bg-2);
padding: 1px 5px;
border-radius: 3px;
margin-left: 6px;
}
.tree-children { margin-left: 12px; display: none; }
.tree-node.expanded > .tree-children { display: block; }

.col-database .icon { color: var(–sf-blue); }
.col-schema .icon { color: var(–purple); }
.col-table .icon { color: var(–text-2); }
.col-view .icon { color: var(–green); }
.col-column .icon { color: var(–text-3); font-size: 10px; }
.col-column .icon span { font-family: ‘JetBrains Mono’, monospace; font-size: 9px; font-weight: 600; }

.worksheet-list { padding: 0 4px 8px; flex: 1; overflow-y: auto; }
.ws-item {
display: flex;
align-items: center;
padding: 5px 6px;
border-radius: var(–radius-sm);
cursor: pointer;
font-size: 12.5px;
color: var(–text-1);
gap: 6px;
}
.ws-item:hover { background: var(–surface-hover); }
.ws-item.active { background: var(–surface-active); }
.ws-item .icon { color: var(–text-2); flex-shrink: 0; }
.ws-item .icon svg { width: 13px; height: 13px; }
.ws-item .label { flex: 1; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.ws-item .meta { font-size: 10.5px; color: var(–text-3); }

/* ===== Workspace ===== */
.workspace {
display: grid;
grid-template-rows: var(–tabs-h) auto 1fr;
background: var(–bg-0);
min-width: 0;
overflow: hidden;
}

.tabs-bar {
display: flex;
align-items: stretch;
background: var(–bg-1);
border-bottom: 1px solid var(–border-1);
height: var(–tabs-h);
overflow-x: auto;
overflow-y: hidden;
}
.tabs-bar::-webkit-scrollbar { height: 0; }
.tab {
display: flex;
align-items: center;
gap: 6px;
padding: 0 10px 0 12px;
height: 100%;
border-right: 1px solid var(–border-1);
font-size: 12.5px;
color: var(–text-2);
cursor: pointer;
background: var(–bg-1);
position: relative;
white-space: nowrap;
user-select: none;
min-width: 110px;
max-width: 200px;
}
.tab:hover { color: var(–text-1); background: var(–bg-2); }
.tab.active {
color: var(–text-1);
background: var(–bg-0);
}
.tab.active::after {
content: ‘’;
position: absolute;
inset: 0 0 -1px 0;
border-bottom: 1px solid var(–bg-0);
pointer-events: none;
}
.tab.active::before {
content: ‘’;
position: absolute;
top: 0; left: 0; right: 0;
height: 2px;
background: var(–sf-blue);
}
.tab .icon svg { width: 12px; height: 12px; color: var(–text-3); }
.tab .name {
overflow: hidden;
text-overflow: ellipsis;
flex: 1;
font-weight: 500;
}
.tab .close {
width: 16px; height: 16px;
border-radius: 3px;
display: inline-flex;
align-items: center;
justify-content: center;
color: var(–text-3);
opacity: 0.5;
transition: background 120ms, opacity 120ms;
}
.tab:hover .close { opacity: 1; }
.tab .close:hover { background: var(–bg-3); color: var(–text-1); }
.tab .close svg { width: 10px; height: 10px; }
.tab .dirty-dot {
width: 6px; height: 6px;
border-radius: 50%;
background: var(–sf-blue);
}
.tab-add {
display: flex;
align-items: center;
justify-content: center;
width: 36px;
color: var(–text-3);
background: var(–bg-1);
}
.tab-add:hover { color: var(–text-1); background: var(–bg-2); }
.tab-add svg { width: 14px; height: 14px; }

/* ===== Toolbar ===== */
.toolbar {
display: flex;
align-items: center;
height: 44px;
padding: 0 12px;
gap: 8px;
background: var(–bg-0);
border-bottom: 1px solid var(–border-1);
}
.btn {
display: inline-flex;
align-items: center;
gap: 6px;
height: 30px;
padding: 0 12px;
border-radius: var(–radius-md);
font-size: 12.5px;
font-weight: 500;
background: var(–bg-2);
color: var(–text-1);
border: 1px solid var(–border-2);
transition: background 100ms, border-color 100ms;
}
.btn:hover:not(:disabled) { background: var(–surface-hover); border-color: var(–border-3); }
.btn:disabled { opacity: 0.5; cursor: not-allowed; }
.btn svg { width: 13px; height: 13px; }
.btn.primary {
background: var(–sf-blue);
border-color: var(–sf-blue);
color: #06121A;
font-weight: 600;
}
.btn.primary:hover:not(:disabled) {
background: var(–sf-blue-dark);
border-color: var(–sf-blue-dark);
}
.btn.primary svg { fill: currentColor; }
.btn.split {
padding-right: 4px;
}
.btn.split .divider {
width: 1px;
height: 16px;
background: rgba(0,0,0,0.2);
margin: 0 4px 0 8px;
}
.kbd {
display: inline-flex;
align-items: center;
font-family: ‘Inter’, sans-serif;
font-size: 10.5px;
font-weight: 500;
padding: 1px 5px;
background: rgba(0,0,0,0.18);
border-radius: 3px;
margin-left: 6px;
letter-spacing: 0.02em;
}
.toolbar .spacer { flex: 1; }
.toolbar-meta {
display: flex;
align-items: center;
gap: 8px;
color: var(–text-3);
font-size: 11.5px;
}
.toolbar-meta .sep { width: 1px; height: 14px; background: var(–border-2); }

/* ===== Editor + results split ===== */
.split {
display: grid;
grid-template-rows: 1fr 8px minmax(120px, var(–results-h, 360px));
min-height: 0;
}
.editor-pane {
background: var(–bg-0);
overflow: hidden;
position: relative;
min-height: 0;
}
.CodeMirror {
height: 100% !important;
background: var(–bg-0) !important;
color: var(–text-1) !important;
font-family: ‘JetBrains Mono’, ui-monospace, monospace !important;
font-size: 13.5px !important;
line-height: 1.6 !important;
}
.CodeMirror-gutters {
background: var(–bg-0) !important;
border-right: 1px solid var(–border-1) !important;
}
.CodeMirror-linenumber { color: var(–text-4) !important; padding: 0 8px 0 12px !important; font-size: 11.5px !important; }
.CodeMirror-cursor { border-left: 1.5px solid var(–sf-blue) !important; }
.CodeMirror-selected { background: rgba(41, 181, 232, 0.18) !important; }
.CodeMirror-focused .CodeMirror-selected { background: rgba(41, 181, 232, 0.25) !important; }
.CodeMirror-activeline-background { background: rgba(255,255,255,0.025) !important; }
.cm-s-default .cm-keyword { color: #FF7A8C !important; font-weight: 500; }
.cm-s-default .cm-atom { color: #B088F9 !important; }
.cm-s-default .cm-number { color: #F5B544 !important; }
.cm-s-default .cm-string { color: #2DD4A8 !important; }
.cm-s-default .cm-string-2 { color: var(–sf-blue-pale) !important; }
.cm-s-default .cm-comment { color: var(–text-3) !important; font-style: italic; }
.cm-s-default .cm-operator { color: var(–text-2) !important; }
.cm-s-default .cm-variable, .cm-s-default .cm-variable-2 { color: var(–text-1) !important; }
.cm-s-default .cm-builtin { color: var(–sf-blue) !important; }
.cm-s-default .cm-def { color: var(–sf-blue-pale) !important; }
.cm-s-default .cm-bracket { color: var(–text-2) !important; }
/* ===== Query History full-page view ===== */
.history-view {
  background: var(–bg-0);
  overflow: hidden;
  display: flex;
  flex-direction: column;
  min-height: 0;
}
.history-header { padding: 24px 28px 12px; }
.history-header h2 {
  font-size: 20px; font-weight: 600; color: var(–text-1);
  letter-spacing: -0.01em; margin-bottom: 4px;
}
.history-sub { font-size: 12.5px; color: var(–text-3); }

.history-filters {
  display: flex; align-items: center; gap: 8px;
  padding: 8px 28px 14px;
  border-bottom: 1px solid var(–border-1);
  flex-wrap: wrap;
}
.history-search {
  display: flex; align-items: center;
  background: var(–bg-1); border: 1px solid var(–border-2);
  border-radius: var(–radius-md);
  padding: 0 10px;
  height: 32px; min-width: 240px; flex: 1; max-width: 360px;
}
.history-search:focus-within { border-color: var(–sf-blue); }
.history-search svg { width: 13px; height: 13px; color: var(–text-3); flex-shrink: 0; margin-right: 6px; }
.history-search input {
  background: none; border: none; outline: none; color: var(–text-1);
  font-size: 13px; flex: 1; height: 100%;
}
.history-filters select {
  background: var(–bg-1); border: 1px solid var(–border-2);
  border-radius: var(–radius-md); color: var(–text-1);
  font-size: 12.5px; height: 32px; padding: 0 26px 0 10px;
  appearance: none; -webkit-appearance: none;
  background-image: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 10 10' fill='%23A6B0BF'><path d='M2 4l3 3 3-3z'/></svg>");
  background-repeat: no-repeat; background-position: right 8px center;
}
.history-filters select:hover { border-color: var(–border-3); }
.history-filters select:focus { outline: none; border-color: var(–sf-blue); }
.history-count { font-size: 11.5px; color: var(–text-3); margin-left: 4px; }
.history-spacer { flex: 1; }

.history-body { flex: 1; overflow: hidden; }
.history-table-wrap {
  height: 100%;
  overflow: auto;
  padding: 0 28px 28px;
}
.history-table {
  width: 100%;
  border-collapse: collapse;
  font-size: 12.5px;
  table-layout: fixed;
}
.history-table thead th {
  position: sticky; top: 0; z-index: 1;
  background: var(–bg-0);
  text-align: left;
  font-weight: 500; color: var(–text-3);
  font-size: 11px; letter-spacing: 0.04em; text-transform: uppercase;
  padding: 12px 12px 10px;
  border-bottom: 1px solid var(–border-2);
}
.history-table .hcol-status { width: 26px; padding-right: 0; }
.history-table .hcol-num    { width: 90px; text-align: right; }
.history-table .hcol-meta   { width: 130px; }
.history-table tbody tr {
  border-bottom: 1px solid var(–border-1);
  cursor: pointer;
  transition: background 80ms;
}
.history-table tbody tr:hover { background: var(–surface-hover); }
.history-table tbody tr.expanded { background: var(–surface-active); }
.history-table tbody td {
  padding: 10px 12px;
  color: var(–text-2);
  vertical-align: top;
}
.history-table tbody td.cell-status { padding: 12px 4px 12px 12px; }
.history-table tbody td.cell-num { text-align: right; font-variant-numeric: tabular-nums; color: var(–text-1); }
.history-table tbody td.cell-sql {
  color: var(–text-1);
  font-family: ‘JetBrains Mono’, ui-monospace, monospace;
  font-size: 12px;
  white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
}
.h-status-icon { width: 14px; height: 14px; display: inline-block; }
.h-status-icon.ok { color: var(–green); }
.h-status-icon.err { color: #FF7A8C; }

.history-detail-row td { padding: 0 !important; background: var(–bg-1); border-bottom: 1px solid var(–border-2); }
.history-detail {
  padding: 16px 28px;
  display: flex; flex-direction: column; gap: 12px;
}
.history-detail .hd-meta {
  display: flex; flex-wrap: wrap; gap: 16px;
  font-size: 11.5px; color: var(–text-3);
}
.history-detail .hd-meta strong { color: var(–text-1); font-weight: 500; }
.history-detail pre {
  background: var(–bg-0); border: 1px solid var(–border-1);
  border-radius: var(–radius-md);
  padding: 12px 14px;
  font-family: ‘JetBrains Mono’, ui-monospace, monospace;
  font-size: 12px; line-height: 1.55;
  color: var(–text-1);
  overflow-x: auto;
  white-space: pre-wrap; word-break: break-word;
}
.history-detail .hd-error {
  border-color: #FF7A8C;
  color: #FF7A8C;
}
.history-detail .hd-actions { display: flex; gap: 8px; }

.history-empty {
  text-align: center;
  color: var(–text-3);
  padding: 60px 0;
  font-size: 13px;
}

@media (max-width: 768px) {
  .history-header { padding: 16px; }
  .history-filters { padding: 8px 16px 12px; }
  .history-search { min-width: 0; max-width: none; }
  .history-table-wrap { padding: 0 16px 24px; }
  .history-table .hcol-meta,
  .history-table .hcol-num { width: auto; }
  .history-table .hcol-meta { display: none; }
  .history-table td.cell-meta { display: none; }
}

/* Autocomplete dropdown (CodeMirror show-hint, themed for Snowsight dark) */
.CodeMirror-hints {
  background: var(–bg-2) !important;
  border: 1px solid var(–border-2) !important;
  border-radius: var(–radius-md) !important;
  box-shadow: 0 8px 32px rgba(0,0,0,0.45) !important;
  padding: 4px 0 !important;
  font-family: ‘JetBrains Mono’, ui-monospace, monospace !important;
  font-size: 12.5px !important;
  max-height: 280px !important;
  z-index: 200 !important;
}
.CodeMirror-hint {
  color: var(–text-1) !important;
  padding: 4px 12px !important;
  white-space: nowrap !important;
}
li.CodeMirror-hint-active {
  background: var(–surface-active) !important;
  color: var(–sf-blue) !important;
}

.cm-statement-active {
background: rgba(41, 181, 232, 0.06);
border-left: 2px solid var(–sf-blue);
margin-left: -2px;
}
.editor-empty {
position: absolute;
inset: 0;
display: flex;
align-items: center;
justify-content: center;
pointer-events: none;
color: var(–text-3);
font-size: 13px;
font-family: ‘JetBrains Mono’, monospace;
}

.resizer {
background: var(–bg-1);
cursor: ns-resize;
position: relative;
border-top: 1px solid var(–border-1);
border-bottom: 1px solid var(–border-1);
}
.resizer::before {
content: ‘’;
position: absolute;
left: 50%;
top: 50%;
transform: translate(-50%, -50%);
width: 32px;
height: 2px;
background: var(–border-3);
border-radius: 1px;
}
.resizer:hover::before { background: var(–sf-blue); }

/* ===== Results pane ===== */
.results-pane {
background: var(–bg-1);
display: grid;
grid-template-rows: 36px 1fr;
min-height: 0;
overflow: hidden;
}
.results-tabs {
display: flex;
align-items: stretch;
background: var(–bg-1);
border-bottom: 1px solid var(–border-1);
padding: 0 4px;
gap: 0;
}
.result-tab {
display: inline-flex;
align-items: center;
gap: 6px;
height: 100%;
padding: 0 12px;
font-size: 12px;
color: var(–text-2);
font-weight: 500;
border-bottom: 2px solid transparent;
margin-bottom: -1px;
}
.result-tab:hover { color: var(–text-1); }
.result-tab.active { color: var(–sf-blue); border-bottom-color: var(–sf-blue); }
.result-tab svg { width: 13px; height: 13px; }
.result-tab .count {
font-size: 10.5px;
background: var(–bg-3);
padding: 1px 5px;
border-radius: 3px;
color: var(–text-2);
font-weight: 500;
}
.result-tab.active .count { background: rgba(41, 181, 232, 0.15); color: var(–sf-blue); }
.results-tabs .spacer { flex: 1; }
.results-tabs .actions {
display: flex; gap: 2px; padding: 4px 4px 0 0; align-items: center;
}

.result-content {
overflow: hidden;
position: relative;
min-height: 0;
}
.result-pane {
position: absolute;
inset: 0;
overflow: auto;
display: none;
}
.result-pane.active { display: block; }

/* Results table */
.result-empty {
position: absolute; inset: 0;
display: flex;
flex-direction: column;
align-items: center;
justify-content: center;
color: var(–text-3);
gap: 8px;
}
.result-empty svg { width: 48px; height: 48px; opacity: 0.4; }
.result-empty .title { font-size: 13px; color: var(–text-2); }
.result-empty .hint { font-size: 11.5px; color: var(–text-4); }

.result-error {
position: absolute; inset: 0;
padding: 24px;
display: flex;
flex-direction: column;
gap: 8px;
}
.result-error .err-head {
display: flex; align-items: center; gap: 8px;
color: var(–red); font-weight: 600; font-size: 13px;
}
.result-error .err-head svg { width: 16px; height: 16px; }
.result-error .err-body {
font-family: ‘JetBrains Mono’, monospace;
font-size: 12px;
color: var(–text-1);
background: var(–red-bg);
border: 1px solid rgba(248, 111, 124, 0.25);
padding: 12px;
border-radius: var(–radius-md);
white-space: pre-wrap;
line-height: 1.5;
}
.result-error .err-hint {
color: var(–text-3); font-size: 12px; margin-top: 4px;
}

table.result-table {
border-collapse: separate;
border-spacing: 0;
width: 100%;
font-size: 12.5px;
font-family: ‘JetBrains Mono’, monospace;
}
table.result-table th, table.result-table td {
border-right: 1px solid var(–border-1);
border-bottom: 1px solid var(–border-1);
padding: 5px 10px;
text-align: left;
white-space: nowrap;
max-width: 360px;
overflow: hidden;
text-overflow: ellipsis;
}
table.result-table thead {
position: sticky;
top: 0;
z-index: 2;
}
table.result-table th {
background: var(–bg-2);
color: var(–text-2);
font-weight: 600;
font-size: 11px;
text-transform: uppercase;
letter-spacing: 0.04em;
font-family: ‘Inter’, sans-serif;
padding: 7px 10px;
border-bottom: 1px solid var(–border-2);
}
table.result-table th .col-meta {
color: var(–text-4);
font-size: 9.5px;
margin-left: 6px;
font-weight: 400;
text-transform: lowercase;
letter-spacing: 0;
}
table.result-table tr.row-num td:first-child {
background: var(–bg-2);
color: var(–text-3);
width: 40px;
text-align: right;
font-size: 11px;
user-select: none;
}
table.result-table tbody tr:hover td {
background: rgba(41, 181, 232, 0.04);
}
table.result-table td.numeric { text-align: right; color: var(–sf-blue-pale); }
table.result-table td.null {
color: var(–text-4); font-style: italic;
}
table.result-table td.string { color: var(–text-1); }
table.result-table td.date { color: #F5B544; }
table.result-table td.bool { color: var(–purple); }

/* Query details panel */
.query-details {
padding: 16px 20px;
display: grid;
gap: 16px;
grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
align-content: start;
}
.detail-card {
background: var(–bg-2);
border: 1px solid var(–border-2);
border-radius: var(–radius-md);
padding: 14px 16px;
display: flex;
flex-direction: column;
gap: 4px;
}
.detail-card .key {
font-size: 10.5px;
text-transform: uppercase;
letter-spacing: 0.05em;
color: var(–text-3);
font-weight: 600;
}
.detail-card .val {
font-size: 18px;
font-weight: 600;
color: var(–text-1);
font-family: ‘JetBrains Mono’, monospace;
}
.detail-card .val.small { font-size: 13px; }
.detail-card .sub {
font-size: 11px;
color: var(–text-3);
margin-top: 2px;
}
.detail-card.full { grid-column: 1 / -1; }

.profile {
display: flex;
flex-direction: column;
gap: 6px;
}
.profile-row {
display: grid;
grid-template-columns: 140px 1fr 80px;
align-items: center;
font-size: 12px;
gap: 12px;
}
.profile-row .pname { color: var(–text-2); font-weight: 500; }
.profile-row .pbar {
height: 14px; background: var(–bg-3); border-radius: 3px; position: relative;
overflow: hidden;
}
.profile-row .pbar-fill {
height: 100%; background: linear-gradient(90deg, var(–sf-blue-deep), var(–sf-blue));
border-radius: 3px;
}
.profile-row .pval { font-family: ‘JetBrains Mono’, monospace; color: var(–text-1); text-align: right; font-size: 11.5px; }

/* Chart pane */
.chart-toolbar {
display: flex;
align-items: center;
gap: 8px;
padding: 10px 14px;
border-bottom: 1px solid var(–border-1);
background: var(–bg-2);
font-size: 12px;
color: var(–text-2);
}
.chart-toolbar select {
background: var(–bg-3);
border: 1px solid var(–border-2);
color: var(–text-1);
height: 26px;
padding: 0 8px;
border-radius: var(–radius-sm);
font-size: 12px;
outline: none;
}
.chart-toolbar select:focus { border-color: var(–sf-blue); }
.chart-area {
position: absolute;
top: 47px; left: 0; right: 0; bottom: 0;
padding: 16px 20px;
}
.chart-svg { width: 100%; height: 100%; }
.chart-svg .axis { stroke: var(–border-2); stroke-width: 1; }
.chart-svg .grid { stroke: var(–border-1); stroke-width: 1; stroke-dasharray: 2 3; }
.chart-svg .axis-label { fill: var(–text-3); font-size: 10.5px; font-family: ‘Inter’, sans-serif; }
.chart-svg .axis-title { fill: var(–text-2); font-size: 11px; font-weight: 500; font-family: ‘Inter’, sans-serif; }
.chart-svg .bar { fill: url(#bar-gradient); transition: opacity 100ms; }
.chart-svg .bar:hover { opacity: 0.8; }
.chart-svg .line { stroke: var(–sf-blue); stroke-width: 2; fill: none; }
.chart-svg .area { fill: url(#area-gradient); }
.chart-svg .point { fill: var(–sf-blue); stroke: var(–bg-1); stroke-width: 2; }

/* ===== Status bar ===== */
.statusbar {
display: flex;
align-items: center;
height: var(–status-h);
padding: 0 12px;
background: var(–bg-1);
border-top: 1px solid var(–border-1);
font-size: 11px;
color: var(–text-3);
gap: 12px;
}
.statusbar .item {
display: flex; align-items: center; gap: 5px;
}
.statusbar .item svg { width: 11px; height: 11px; }
.statusbar .item.ok { color: var(–green); }
.statusbar .item.err { color: var(–red); }
.statusbar .item.warn { color: var(–amber); }
.statusbar .spacer { flex: 1; }

/* ===== Toasts ===== */
.toasts {
position: fixed;
bottom: 36px;
right: 16px;
display: flex;
flex-direction: column;
gap: 8px;
z-index: 200;
pointer-events: none;
}
.toast {
background: var(–bg-3);
border: 1px solid var(–border-3);
border-left: 3px solid var(–sf-blue);
padding: 10px 14px;
border-radius: var(–radius-md);
box-shadow: var(–shadow-lg);
font-size: 12.5px;
color: var(–text-1);
display: flex;
align-items: center;
gap: 8px;
pointer-events: auto;
animation: toast-in 200ms cubic-bezier(0.2, 0.8, 0.2, 1);
max-width: 360px;
}
.toast.success { border-left-color: var(–green); }
.toast.error { border-left-color: var(–red); }
.toast.warn { border-left-color: var(–amber); }
.toast svg { width: 14px; height: 14px; flex-shrink: 0; }
@keyframes toast-in {
from { opacity: 0; transform: translateX(20px); }
to { opacity: 1; transform: translateX(0); }
}

/* ===== Loading bar ===== */
.loading-bar {
position: absolute;
top: 0; left: 0; right: 0;
height: 2px;
background: var(–bg-2);
overflow: hidden;
z-index: 10;
display: none;
}
.loading-bar.active { display: block; }
.loading-bar::after {
content: ‘’;
position: absolute;
top: 0; left: -30%;
width: 30%;
height: 100%;
background: linear-gradient(90deg, transparent, var(–sf-blue), transparent);
animation: loading-slide 1.2s ease-in-out infinite;
}
@keyframes loading-slide {
0% { left: -30%; }
100% { left: 100%; }
}

/* ===== Boot overlay ===== */
.boot-overlay {
position: fixed;
inset: 0;
background: var(–bg-0);
display: flex;
flex-direction: column;
align-items: center;
justify-content: center;
z-index: 1000;
gap: 20px;
}
.boot-overlay.hide { animation: boot-fade 400ms forwards; }
@keyframes boot-fade {
to { opacity: 0; visibility: hidden; }
}
.boot-mark {
width: 64px; height: 64px;
animation: boot-pulse 1.4s ease-in-out infinite;
}
@keyframes boot-pulse {
0%, 100% { opacity: 1; transform: scale(1); }
50% { opacity: 0.7; transform: scale(0.95); }
}
.boot-text {
font-size: 13px;
color: var(–text-3);
font-family: ‘JetBrains Mono’, monospace;
}
.boot-progress {
width: 240px;
height: 2px;
background: var(–bg-2);
border-radius: 1px;
overflow: hidden;
}
.boot-progress-fill {
height: 100%;
background: var(–sf-blue);
width: 0%;
transition: width 200ms ease;
}

/* ===== Modals ===== */
.modal-backdrop {
position: fixed; inset: 0;
background: rgba(5, 8, 14, 0.7);
backdrop-filter: blur(2px);
z-index: 100;
display: none;
align-items: center;
justify-content: center;
padding: 40px;
}
.modal-backdrop.open { display: flex; }
.modal {
background: var(–bg-2);
border: 1px solid var(–border-3);
border-radius: var(–radius-lg);
box-shadow: var(–shadow-lg);
width: 100%;
max-width: 720px;
max-height: 80vh;
display: flex;
flex-direction: column;
overflow: hidden;
}
.modal-head {
display: flex; align-items: center;
padding: 14px 18px;
border-bottom: 1px solid var(–border-2);
}
.modal-head h3 { font-size: 14px; font-weight: 600; color: var(–text-1); flex: 1; }
.modal-body { padding: 16px 18px; overflow-y: auto; flex: 1; }
.modal-foot {
padding: 12px 18px;
border-top: 1px solid var(–border-2);
display: flex;
justify-content: flex-end;
gap: 8px;
}

.history-item {
padding: 10px 12px;
border: 1px solid var(–border-2);
border-radius: var(–radius-md);
margin-bottom: 8px;
cursor: pointer;
transition: border-color 120ms;
background: var(–bg-1);
}
.history-item:hover { border-color: var(–sf-blue); }
.history-item .h-meta {
display: flex; gap: 12px; font-size: 11px; color: var(–text-3); margin-bottom: 6px;
align-items: center;
}
.history-item .h-meta .h-status {
display: inline-flex; align-items: center; gap: 4px;
}
.history-item .h-meta .h-status.ok { color: var(–green); }
.history-item .h-meta .h-status.err { color: var(–red); }
.history-item .h-sql {
font-family: ‘JetBrains Mono’, monospace;
font-size: 12px;
color: var(–text-1);
white-space: pre-wrap;
max-height: 120px;
overflow: hidden;
position: relative;
}
.history-item .h-sql::after {
content: ‘’;
position: absolute;
bottom: 0; left: 0; right: 0;
height: 30px;
background: linear-gradient(transparent, var(–bg-1));
pointer-events: none;
}

/* Dropdown menu */
.menu {
position: absolute;
background: var(–bg-3);
border: 1px solid var(–border-3);
border-radius: var(–radius-md);
box-shadow: var(–shadow-lg);
padding: 4px;
min-width: 200px;
z-index: 80;
display: none;
}
.menu.open { display: block; }
.menu-item {
display: flex;
align-items: center;
gap: 8px;
padding: 7px 10px;
font-size: 12.5px;
color: var(–text-1);
border-radius: var(–radius-sm);
cursor: pointer;
}
.menu-item:hover { background: var(–surface-active); color: var(–sf-blue); }
.menu-item svg { width: 13px; height: 13px; color: var(–text-2); }
.menu-item .right { margin-left: auto; color: var(–text-3); font-size: 10.5px; }
.menu-item.active { color: var(–sf-blue); }
.menu-divider { height: 1px; background: var(–border-2); margin: 4px 0; }
.menu-section {
font-size: 10.5px;
text-transform: uppercase;
color: var(–text-3);
padding: 6px 10px 4px;
letter-spacing: 0.05em;
font-weight: 600;
}

/* Templates panel */
.templates-grid {
display: grid;
grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
gap: 10px;
}
.template-card {
background: var(–bg-1);
border: 1px solid var(–border-2);
border-radius: var(–radius-md);
padding: 12px 14px;
cursor: pointer;
transition: border-color 120ms;
}
.template-card:hover { border-color: var(–sf-blue); }
.template-card .t-title { font-size: 13px; font-weight: 600; color: var(–text-1); margin-bottom: 4px; }
.template-card .t-desc { font-size: 11.5px; color: var(–text-3); line-height: 1.4; }
.template-card .t-tag {
display: inline-block;
font-size: 9.5px;
text-transform: uppercase;
letter-spacing: 0.05em;
color: var(–sf-blue);
background: rgba(41, 181, 232, 0.1);
padding: 2px 6px;
border-radius: 3px;
margin-top: 8px;
font-weight: 600;
}

/* About modal */
.about-body { font-size: 13px; color: var(–text-2); line-height: 1.55; }
.about-body p { margin: 0 0 14px; }
.about-hero {
display: flex; align-items: center; gap: 14px;
padding: 14px 16px; margin-bottom: 18px;
background: linear-gradient(135deg, rgba(41,181,232,0.08), rgba(41,181,232,0.02));
border: 1px solid rgba(41,181,232,0.18);
border-radius: 8px;
}
.about-section { margin: 16px 0; }
.about-section h4 {
font-size: 11px; font-weight: 600; color: var(–text-3);
text-transform: uppercase; letter-spacing: 0.06em;
margin: 0 0 8px;
}
.about-section ul { margin: 0; padding-left: 18px; }
.about-section li { margin-bottom: 6px; }
.about-body code {
font-family: ‘JetBrains Mono’, monospace;
font-size: 11.5px;
background: rgba(255,255,255,0.06);
border: 1px solid var(–border-1);
padding: 1px 5px;
border-radius: 3px;
color: var(–text-1);
}
.about-body a { color: var(–sf-blue); text-decoration: none; }
.about-body a:hover { text-decoration: underline; }
.about-foot {
margin-top: 18px; padding-top: 14px;
border-top: 1px solid var(–border-1);
display: flex; gap: 8px; align-items: center;
font-size: 12px; color: var(–text-3);
}

/* Scrollbars */
::-webkit-scrollbar { width: 10px; height: 10px; }
::-webkit-scrollbar-track { background: transparent; }
::-webkit-scrollbar-thumb {
background: var(–bg-3);
border-radius: 5px;
border: 2px solid transparent;
background-clip: content-box;
}
::-webkit-scrollbar-thumb:hover { background: var(–bg-4); background-clip: content-box; border: 2px solid transparent; }

/* ===== Ask AI ===== */
.ai-btn {
  position: relative;
  background: linear-gradient(135deg, rgba(41,181,232,0.14), rgba(176,136,249,0.14)) !important;
  border-color: rgba(41,181,232,0.35) !important;
  color: var(–text-1) !important;
}
.ai-btn:hover {
  background: linear-gradient(135deg, rgba(41,181,232,0.22), rgba(176,136,249,0.22)) !important;
  border-color: var(–sf-blue) !important;
}
.ai-btn svg { color: var(–sf-blue); }

.ai-panel { display: flex; flex-direction: column; gap: 12px; }
.ai-lead { color: var(–text-2); font-size: 12.5px; line-height: 1.5; }
.ai-hint { color: var(–text-3); font-size: 11.5px; line-height: 1.5; }
.ai-hint a { color: var(–sf-blue); text-decoration: none; }
.ai-hint a:hover { text-decoration: underline; }
.ai-hint code { background: var(–bg-1); padding: 1px 5px; border-radius: 3px; font-family: ‘JetBrains Mono’, monospace; font-size: 11px; color: var(–text-2); }
.ai-lead code { background: var(–bg-1); padding: 1px 5px; border-radius: 3px; font-family: ‘JetBrains Mono’, monospace; font-size: 11px; color: var(–text-2); }

.ai-input {
  width: 100%;
  background: var(–bg-1);
  border: 1px solid var(–border-2);
  border-radius: var(–radius-md);
  color: var(–text-1);
  font-family: inherit;
  font-size: 13px;
  padding: 9px 11px;
  outline: none;
  transition: border-color 120ms;
  resize: vertical;
}
.ai-input:focus { border-color: var(–sf-blue); }
.ai-input::placeholder { color: var(–text-3); }

.ai-row { display: flex; align-items: center; gap: 8px; }
.ai-spacer { flex: 1; }
.ai-status {
  font-size: 12px;
  color: var(–text-3);
  min-height: 16px;
  font-family: ‘JetBrains Mono’, monospace;
}
.ai-status.error { color: #FF7A8C; white-space: pre-wrap; word-break: break-word; }

/* Utility */
.hidden { display: none !important; }

/* ============================================================
   MOBILE (≤768px) — sidebar drawer, single-column main grid
   ============================================================ */
.mobile-menu-btn { display: none; }
.scrim { display: none; }

@media (max-width: 768px) {
  .mobile-menu-btn {
    display: inline-flex;
    width: 44px; height: 44px;
    margin-right: 4px;
  }
  .mobile-menu-btn svg { width: 18px; height: 18px; }

  .brand-text { display: none; }
  .nav-tabs { display: none; }

  /* Pills shrink — keep value, drop label, shrink padding */
  .pill { height: 36px; padding: 0 8px; }
  .pill .label { display: none; }

  /* Touch target floor */
  .icon-btn { width: 44px; height: 44px; }
  .avatar { width: 36px; height: 36px; font-size: 12px; }

  /* Single-column main; sidebar becomes a fixed left drawer */
  .main { grid-template-columns: 1fr; }

  .sidebar {
    position: fixed;
    top: var(–header-h);
    left: 0;
    bottom: var(–status-h);
