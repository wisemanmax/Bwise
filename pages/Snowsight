// ---------- Engine adapter (Phase 0a/0b) ----------
// Wraps the underlying SQL engine behind a stable async interface. Both
// adapters return result sets in the sql.js shape Array<{columns, values}>.
// engine.kind is consumed by translateSnowflake(sql, target) so the caller
// gets engine-appropriate SQL without deciding which translator to use.
function createEngine(kind) {
  if (kind === 'sqljs')  return createSqljsEngine();
  if (kind === 'duckdb') return createDuckDBEngine();
  throw new Error(`Unknown engine: ${kind}. Valid: sqljs, duckdb.`);
}

function createSqljsEngine() {
  let db = null;
  return {
    kind: 'sqljs',
    get ready() { return db !== null; },
    async init() {
      const SQL = await initSqlJs({
        locateFile: f => `https://cdnjs.cloudflare.com/ajax/libs/sql.js/1.10.3/${f}`
      });
      db = new SQL.Database();
    },
    async exec(sql) {
      return db.exec(sql);
    },
    async bulkInsert(table, cols, rows) {
      if (!rows.length) return;
      const placeholders = '(' + cols.map(_ => '?').join(',') + ')';
      const stmt = db.prepare(`INSERT INTO ${table} (${cols.join(',')}) VALUES ${placeholders}`);
      db.exec('BEGIN');
      try { for (const row of rows) stmt.run(row); }
      finally { stmt.free(); db.exec('COMMIT'); }
    }
  };
}

function createDuckDBEngine() {
  const DUCKDB_VERSION = '1.29.0';
  let conn = null;
  return {
    kind: 'duckdb',
    get ready() { return conn !== null; },
    async init() {
      const duckdb = await import(`https://cdn.jsdelivr.net/npm/@duckdb/duckdb-wasm@${DUCKDB_VERSION}/+esm`);
      const bundles = duckdb.getJsDelivrBundles();
      const bundle = await duckdb.selectBundle(bundles);
      const workerUrl = URL.createObjectURL(
        new Blob([`importScripts("${bundle.mainWorker}");`], { type: 'text/javascript' })
      );
      const worker = new Worker(workerUrl);
      const logger = new duckdb.ConsoleLogger();
      const db = new duckdb.AsyncDuckDB(logger, worker);
      await db.instantiate(bundle.mainModule, bundle.pthreadWorker);
      URL.revokeObjectURL(workerUrl);
      conn = await db.connect();
    },
    async exec(sql) {
      const trimmed = String(sql).trim().replace(/;\s*$/, '');
      if (!trimmed) return [];
      const table = await conn.query(trimmed);
      return arrowToSqljs(table);
    },
    async bulkInsert(table, cols, rows) {
      if (!rows.length) return;
      // Chunked INSERT VALUES — DuckDB-WASM's prepared-statement API differs
      // enough from sql.js that batched literals are simpler and fast enough
      // for the synthetic dataset (~36K rows total).
      const CHUNK = 1000;
      const colList = cols.join(', ');
      for (let i = 0; i < rows.length; i += CHUNK) {
        const chunk = rows.slice(i, i + CHUNK);
        const valueRows = chunk.map(r =>
          '(' + r.map(v => duckdbLiteral(v)).join(', ') + ')'
        ).join(', ');
        await conn.query(`INSERT INTO ${table} (${colList}) VALUES ${valueRows}`);
      }
    }
  };
}

// Convert one JS scalar to a DuckDB SQL literal. Handles null/number/string;
// strings are single-quoted with single-quote doubling.
function duckdbLiteral(v) {
  if (v === null || v === undefined) return 'NULL';
  if (typeof v === 'number') return Number.isFinite(v) ? String(v) : 'NULL';
  if (typeof v === 'boolean') return v ? 'TRUE' : 'FALSE';
  return `'${String(v).replace(/'/g, "''")}'`;
}

// DuckDB Arrow Table → sql.js shape. Normalizes BigInt and Date so the
// downstream UI (which was written for sql.js) doesn't need to know the
// difference.
function arrowToSqljs(table) {
  if (!table || !table.schema) return [];
  const columns = table.schema.fields.map(f => f.name);
  const out = [];
  for (const row of table.toArray()) {
    out.push(columns.map(c => normalizeDuckValue(row[c])));
  }
  return [{ columns, values: out }];
}

function normalizeDuckValue(v) {
  if (v === null || v === undefined) return null;
  if (typeof v === 'bigint') {
    if (v >= Number.MIN_SAFE_INTEGER && v <= Number.MAX_SAFE_INTEGER) return Number(v);
    return v.toString();
  }
  if (v instanceof Date) return v.toISOString().slice(0, 10);
  if (typeof v === 'object') {
    if (typeof v.days !== 'undefined') {
      const days = Number(v.days);
      return new Date(days * 86400000).toISOString().slice(0, 10);
    }
    if (typeof v.micros !== 'undefined') {
      const micros = Number(v.micros);
      return new Date(micros / 1000).toISOString().slice(0, 10);
    }
  }
  return v;
}

function selectedEngineKind() {
  try {
    const v = new URLSearchParams(window.location.search).get('engine');
    return v || 'sqljs';
  } catch (_) { return 'sqljs'; }
}

