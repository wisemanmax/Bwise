function renderResults() {
  const r = state.results;
  const tablePane = $('#pane-table');
  if (!r) {
    tablePane.innerHTML = `<div class="result-empty">
      <svg viewBox="0 0 64 64" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="10" y="14" width="44" height="36" rx="2"/><path d="M10 24h44M22 14v36"/></svg>
