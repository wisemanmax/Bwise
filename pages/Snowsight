// ---------- Query History page ----------
const HIST_FILTERS = { search: '', status: '', range: '' };
let _histExpandedQid = null;

function applyHistoryFilters(items) {
  const q = HIST_FILTERS.search.trim().toLowerCase();
  const st = HIST_FILTERS.status;
  const range = HIST_FILTERS.range;
  const now = Date.now();
  const cutoff = range === '1h' ? now - 3600e3
               : range === '24h' ? now - 86400e3
               : range === '7d' ? now - 7 * 86400e3
               : 0;
  return items.filter(h => {
    if (q && !(h.sql || '').toLowerCase().includes(q)) return false;
    if (st === 'ok'  && !h.ok) return false;
    if (st === 'err' && h.ok)  return false;
    if (cutoff && h.ts < cutoff) return false;
    return true;
  });
}

function renderHistoryPage() {
  const tbody = $('#histTbody');
  const empty = $('#histEmpty');
  const count = $('#histCount');
  tbody.innerHTML = '';
  const filtered = applyHistoryFilters(state.history);
  count.textContent = `${filtered.length} of ${state.history.length}`;
  if (!filtered.length) {
    empty.hidden = false;
    return;
  }
  empty.hidden = true;
  for (const h of filtered) {
    tbody.appendChild(buildHistoryRow(h));
    if (h.qid === _histExpandedQid) tbody.appendChild(buildHistoryDetail(h));
  }
}

function buildHistoryRow(h) {
  const okIcon = '<svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" class="h-status-icon ok"><path d="M3 8l3.5 3.5L13 5"/></svg>';
  const errIcon = '<svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" class="h-status-icon err"><circle cx="8" cy="8" r="6"/><path d="M5 5l6 6M11 5l-6 6"/></svg>';
  const tr = el('tr', {
    class: h.qid === _histExpandedQid ? 'expanded' : '',
    onclick: () => {
      _histExpandedQid = (_histExpandedQid === h.qid) ? null : h.qid;
      renderHistoryPage();
    }
  });
  tr.appendChild(el('td', { class: 'cell-status', html: h.ok ? okIcon : errIcon }));
  tr.appendChild(el('td', { class: 'cell-sql', title: h.sql }, (h.sql || '').replace(/\s+/g, ' ').slice(0, 200)));
  tr.appendChild(el('td', { class: 'cell-num' }, h.ok ? formatNum(h.rows) : '—'));
  tr.appendChild(el('td', { class: 'cell-num' }, formatDuration(h.duration)));
  tr.appendChild(el('td', { class: 'cell-num' }, h.bytesScanned ? formatBytes(h.bytesScanned) : '—'));
  tr.appendChild(el('td', { class: 'cell-meta' }, h.warehouse || '—'));
  tr.appendChild(el('td', { class: 'cell-meta', title: new Date(h.ts).toLocaleString() }, formatRelTime(h.ts)));
  return tr;
}

function buildHistoryDetail(h) {
  const tr = el('tr', { class: 'history-detail-row' });
  const td = el('td', { colspan: '7' });
